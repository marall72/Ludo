@using Ludo.ViewModels
@model Ludo.ViewModels.EditGame


@{
    ViewData["Title"] = "ثبت بازی جدید";
}

<div class="container">
    <div class="form-signin">
        <h1 class="h3 mb-3 fw-normal text-center">@ViewData["Title"]</h1>
        <div class="btn-group-custom">
            <a href="@Url.Action("index", "games")" class="btn btn-info">
                <i class="bi bi-plus-circle"></i> فهرست بازی ها
            </a>
            @if (Model.Id > 0)
            {
                <a href="@Url.Action("new", "games", new{ id = ""})" class="btn btn-info">
                    <i class="bi bi-plus-circle"></i> بازی جدید
                </a>
            }
        </div>
        @Html.Partial("_Result")

        @using (Html.BeginForm("new", "games", FormMethod.Post, null))
        {
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
            @Html.HiddenFor(x => x.Id)
            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control", style = "text-align: left;direction: ltr;"} })
                @Html.LabelFor(model => model.Title)
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                @Html.CheckBoxFor(model => model.IsActive, new { @class = "form-check-input" })
                @Html.LabelFor(model => model.IsActive, new { @class = "form-check-label" })
            </div>
        <div>
            <button class="btn btn-primary" type="submit">ذخیره</button>
                @if(Model.Id > 0)
                {
                    <a class="btn btn-danger" onclick="confirmDelete('@Model.Id')" >
                        <i class="bi bi-trash"></i> حذف
                    </a>
                }
        </div>
                }

        <p class="mt-4 mb-3 text-body-secondary text-center">&copy; ۱۴۰۳</p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function confirmDelete(userId) {
            if (confirm('آیا از حذف این بازی مطمئن هستید؟')) {

                window.location.href = '@Url.Action("delete", "games")?id=' + userId;
            }
        }
    </script>
}