@model Ludo.ViewModels.GameSelection

<div class="form-floating mb-3" id="levelWrapper">
    @Html.ListBoxFor(model => model.SelectedGamesIds, Model.Games, new { multiple = "multiple", @class = "form-select select2", style = "height: 200px;", id = "Reservation_Games_SelectedGamesIds", name = "Reservation.Games.SelectedGamesIds" })
    @Html.LabelFor(model => model.SelectedGamesIds)
</div>

<script>
    $(document).ready(function(){
        SetGamesNames();
    })
    SetGamesNames();
    function SetGamesNames(){
        $("#Reservation_Games_SelectedGamesIds").attr("name", "Reservation.Games.SelectedGamesIds");
    }
</script>