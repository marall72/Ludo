@using Ludo.ViewModels
@model ToastViewModel


<div class="liveToast toast bg-success text-bg-success" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header">
        <div>
            <strong class="me-auto">@Model.Header</strong>
            @* <small>11 دقیقه پیش</small> *@
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body">
        @Model.Message
    </div>
</div>