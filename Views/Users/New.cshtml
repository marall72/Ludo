@model Ludo.ViewModels.EditUser


@{
    ViewData["Title"] = "ثبت نام کاربر جدید";
}

<div class="container">
    <div class="form-signin">
        <h1 class="h3 mb-3 fw-normal text-center">@ViewData["Title"]</h1>
        <div class="btn-group-custom">
            <a href="@Url.Action("index", "users")" class="btn btn-info">
                <i class="bi bi-plus-circle"></i> فهرست کاربران
            </a>
            @if(Model.Id > 0)
            {
                <a href="@Url.Action("new", "users", new { id = "" })" class="btn btn-info">
                    <i class="bi bi-plus-circle"></i> کاربر جدید
                </a>
            }
        </div>
        @Html.Partial("_Result")

        @using (Html.BeginForm("New", "Users", FormMethod.Post, null))
        {
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
            @Html.HiddenFor(x => x.Id)
            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Firstname, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.Firstname)
                <span asp-validation-for="Firstname" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Lastname, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.Lastname)
                <span asp-validation-for="Lastname" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.Email)
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>


            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Mobile, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.Mobile)
                <span asp-validation-for="Mobile" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Username, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.Username)
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Password, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.Password)
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                @Html.CheckBoxFor(model => model.IsAdmin, new { @class = "form-check-input" })
                @Html.LabelFor(model => model.IsAdmin, new { @class = "form-check-label" })
            </div>
            <div class="form-check mb-3">
                @Html.CheckBoxFor(model => model.IsActive, new { @class = "form-check-input" })
                @Html.LabelFor(model => model.IsActive, new { @class = "form-check-label" })
            </div>
            <button class="btn btn-primary" type="submit">ذخیره</button>
            @if (Model.Id > 0)
            {
                <a class="btn btn-danger" onclick="confirmDelete('@Model.Id')">
                    <i class="bi bi-trash"></i> حذف
                </a>
            }
        }

        <p class="mt-4 mb-3 text-body-secondary text-center">&copy; ۱۴۰۳</p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function confirmDelete(userId) {
            if (confirm('آیا از حذف این کاربر مطمئن هستید؟')) {

                window.location.href = '@Url.Action("delete", "users")?id=' + userId;
            }
        }
    </script>
}
