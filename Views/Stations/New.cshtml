@model Ludo.ViewModels.EditStation


@{
    if(Model.Id > 0)
    {
        ViewData["Title"] = "ویرایش سیستم";
    }
    else
    {
        ViewData["Title"] = "ثبت سیستم جدید";
    }
}

<div class="container">
    <div class="form-signin">
        <h4 class="h4">@ViewData["Title"]</h4>
        <div class="btn-group-custom">
            <a href="@Url.Action("mapedit", "stations")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> نقشه سیستم ها
            </a>
            <a href="@Url.Action("index", "stations")" class="btn btn-info">
                <i class="bi bi-plus-circle"></i> فهرست سیستم ها
            </a>
            @if (Model.Id > 0)
            {
                <a href="@Url.Action("new", "stations", new { id = "" })" class="btn btn-info">
                    <i class="bi bi-plus-circle"></i> سیستم جدید
                </a>
            }
        </div>

        @Html.Partial("_Result")

        @using (Html.BeginForm("New", "stations", FormMethod.Post, null))
        {
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
            @Html.HiddenFor(x => x.Id)
            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.Title)
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.Description, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.Description)
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                @Html.EditorFor(model => model.PlayerCount, new { htmlAttributes = new { @class = "form-control" } })
                @Html.LabelFor(model => model.PlayerCount)
                <span asp-validation-for="PlayerCount" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                @Html.DropDownListFor(model => model.SelectedStationType, Model.StationTypes, null, new { @class = "form-select", onChange = "TypeToggle()", id = "stationTypeDropdown" })
                @Html.LabelFor(model => model.SelectedStationType)
                <span asp-validation-for="SelectedStationType" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3" id="levelWrapper">
                @Html.DropDownListFor(model => model.SelectedStationLevel, Model.StationLevels, null, new { @class = "form-select" })
                @Html.LabelFor(model => model.SelectedStationLevel)
                <span asp-validation-for="SelectedStationLevel" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                @Html.CheckBoxFor(model => model.IsActive, new { @class = "form-check-input" })
                @Html.LabelFor(model => model.IsActive, new { @class = "form-check-label" })
            </div>


            <button class="btn btn-primary" type="submit">ذخیره</button>
            @if (Model.Id > 0)
            {
                <a class="btn btn-danger" onclick="confirmDelete('@Model.Id')">
                    <i class="bi bi-trash"></i> حذف
                </a>
            }
        }

        <p class="mt-4 mb-3 text-body-secondary text-center">&copy; ۱۴۰۳</p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function(){
            TypeToggle();
        });

        function TypeToggle(){
             if($("#stationTypeDropdown").val() == "@((int)Ludo.Models.StationType.PC)"){
                 $("#levelWrapper").show();
             }
             else{
                     $("#levelWrapper").hide();
             }

         }

          function confirmDelete(stationId) {
            if (confirm('آیا از حذف این سیستم مطمئن هستید؟')) {

                window.location.href = '@Url.Action("delete", "stations")?id=' + stationId;
            }
        }
    </script>
}
